+          <a href="/#contato" onClick={() => setDrawer(false)}>Contato</a>
+        </nav>
+        <a className="btn btn-primary btn-cta btn-block" href="/">Reservar locker</a>
+      </aside>
+    </header>
+  );
+}
+
+/* ---- Related card ---- */
+function RelatedCard({ post }) {
+  return (
+    <Link to={`/blog/${post.slug}`} className="blog-related-card">
+      {post.cover_image_url
+        ? <img className="blog-related-img" src={post.cover_image_url} alt={post.cover_image_alt || post.title} loading="lazy" />
+        : <div className="blog-related-img blog-related-img-placeholder"><Icon name="package" size={24} color="var(--navy-400)" /></div>
+      }
+      <div className="blog-related-body">
+        <span className="blog-cat-pill">{post.category}</span>
+        <p className="blog-related-title">{post.title}</p>
+        <span className="blog-card-meta-item"><Icon name="clock" size={12} color="var(--navy-400)" />{post.read_time_min ?? 1} min</span>
+      </div>
+    </Link>
+  );
+}
+
+/* ---- Share bar ---- */
+function ShareBar({ url, title }) {
+  const [copied, setCopied] = useState(false);
+  const wppText = encodeURIComponent(`${title}\n${url}`);
+  const copy = async () => {
+    await navigator.clipboard.writeText(url).catch(() => {});
+    setCopied(true);
+    setTimeout(() => setCopied(false), 2000);
+  };
+  return (
+    <div className="blog-share">
+      <span className="blog-share-label t-label" style={{ color: "var(--navy-300)" }}>Compartilhar:</span>
+      <a className="blog-share-btn blog-share-wpp" href={`https://wa.me/?text=${wppText}`} target="_blank" rel="noopener noreferrer" aria-label="Compartilhar no WhatsApp">
+        <Icon name="phone" size={16} color="var(--cream-500)" /> WhatsApp
+      </a>
+      <button className="blog-share-btn blog-share-copy" onClick={copy} aria-label="Copiar link">
+        <Icon name={copied ? "check" : "download"} size={16} color="var(--navy-900)" />
+        {copied ? "Copiado!" : "Copiar link"}
+      </button>
+    </div>
+  );
+}
+
+/* ---- JSON-LD builder ---- */
+function buildJsonLd(post, url) {
+  const base = {
+    "@context": "https://schema.org",
+    "author": { "@type": "Organization", "name": "Malex" },
+    "publisher": {
+      "@type": "Organization",
+      "name": "Malex",
+      "logo": { "@type": "ImageObject", "url": `${SITE_URL}/favicon.svg` }
+    },
+    "datePublished": post.published_at || post.created_at,
+    "dateModified": post.updated_at || post.published_at || post.created_at,
+    "url": url,
+  };
+  if (post.schema_type === "FAQ") {
+    return JSON.stringify({
+      ...base,
+      "@type": "FAQPage",
+      "name": post.seo_title || post.title,
+      "description": post.meta_description || post.summary,
+    });
+  }
+  if (post.schema_type === "LocalBusiness") {
+    return JSON.stringify({
+      ...base,
+      "@type": "LocalBusiness",
+      "name": post.seo_title || post.title,
+      "description": post.meta_description || post.summary,
+      "image": post.cover_image_url,
+    });
+  }
+  return JSON.stringify({
+    ...base,
+    "@type": "Article",
+    "headline": post.seo_title || post.title,
+    "description": post.meta_description || post.summary,
+    "image": post.cover_image_url ? [post.cover_image_url] : undefined,
+    "mainEntityOfPage": { "@type": "WebPage", "@id": url },
+  });
+}
+
+/* ---- Main ---- */
+export default function BlogPost() {
+  const { slug } = useParams();
+  const navigate = useNavigate();
+  const [post, setPost] = useState(null);
+  const [related, setRelated] = useState([]);
+  const [loading, setLoading] = useState(true);
+  const [notFound, setNotFound] = useState(false);
+
+  useEffect(() => {
+    setLoading(true);
+    setNotFound(false);
+    getPublishedPost(slug).then(({ data, error }) => {
+      if (error || !data) { setNotFound(true); setLoading(false); return; }
+      setPost(data);
+      setLoading(false);
+      getRelatedPosts(data.category, slug).then(setRelated);
+    });
+  }, [slug]);
+
+  if (loading) {
+    return (
+      <>
+        <BlogNav />
+        <div className="blog-post-skeleton-wrap">
+          <div className="blog-post-skeleton">
+            <div className="skeleton" style={{ height: 24, width: 120, borderRadius: 8 }} />
+            <div className="skeleton" style={{ height: 48, marginTop: 16, borderRadius: 8 }} />
+            <div className="skeleton" style={{ height: 48, width: "70%", borderRadius: 8 }} />
+            <div className="skeleton" style={{ height: 300, marginTop: 32, borderRadius: 16 }} />
+            {Array.from({ length: 6 }).map((_, i) => (
+              <div key={i} className="skeleton" style={{ height: 18, marginTop: 12, width: i % 3 === 0 ? "85%" : "100%", borderRadius: 4 }} />
+            ))}
+          </div>
+        </div>
+      </>
+    );
+  }
+
+  if (notFound) {
+    return (
+      <>
+        <BlogNav />
+        <div className="blog-notfound on-navy">
+          <Icon name="package" size={48} color="var(--navy-400)" />
+          <h1 className="t-h2" style={{ color: "var(--cream-500)", marginTop: 16 }}>Artigo não encontrado</h1>
+          <p className="t-body" style={{ color: "var(--navy-300)", marginTop: 8 }}>O artigo que você procura não existe ou foi removido.</p>
+          <Link to="/blog" className="btn btn-primary btn-cta" style={{ marginTop: 24 }}>Ver todos os artigos</Link>
+        </div>
+      </>
+    );
+  }
+
+  const postUrl = `${SITE_URL}/blog/${post.slug}`;
+  const seTitle = post.seo_title || post.title;
+  const seDesc = post.meta_description || post.summary || "";
+
+  return (
+    <>
+      <Helmet>
+        <title>{seTitle} — Blog Malex</title>
+        <meta name="description" content={seDesc} />
+        <link rel="canonical" href={postUrl} />
+        {post.main_keyword && <meta name="keywords" content={[post.main_keyword, ...(post.secondary_keywords || [])].join(", ")} />}
+        <meta property="og:type" content="article" />
+        <meta property="og:title" content={seTitle} />
+        <meta property="og:description" content={seDesc} />
+        <meta property="og:url" content={postUrl} />
+        {post.cover_image_url && <meta property="og:image" content={post.cover_image_url} />}
+        <meta property="article:published_time" content={post.published_at || post.created_at} />
+        <meta property="article:modified_time" content={post.updated_at} />
+        <meta property="article:author" content="Malex" />
+        <meta property="article:section" content={post.category} />
+        {(post.tags || []).map((t) => <meta key={t} property="article:tag" content={t} />)}
+        <script type="application/ld+json">{buildJsonLd(post, postUrl)}</script>
+      </Helmet>
+
+      <BlogNav />
+
+      <main className="blog-post-main">
+        {/* Breadcrumb */}
+        <div className="blog-breadcrumb on-navy">
+          <div className="container blog-breadcrumb-inner">
+            <Link to="/blog">Blog</Link>
+            <Icon name="chevron-right" size={14} color="var(--navy-400)" />
+            <span>{post.category}</span>
+          </div>
+        </div>
+
+        {/* Header */}
+        <header className="blog-post-header on-navy">
+          <div className="container blog-post-header-inner">
+            <span className="blog-cat-pill">{post.category}</span>
+            <h1 className="blog-post-title">{post.title}</h1>
+            {post.summary && <p className="blog-post-summary">{post.summary}</p>}
+            <div className="blog-post-meta">
+              <span className="blog-post-meta-item">
+                <Icon name="user" size={14} color="var(--navy-400)" /> {post.author || "Malex"}
+              </span>
+              {post.published_at && (
+                <span className="blog-post-meta-item">
+                  <Icon name="calendar-check" size={14} color="var(--navy-400)" /> {fmtDate(post.published_at)}
+                </span>
+              )}
+              <span className="blog-post-meta-item">
+                <Icon name="clock" size={14} color="var(--navy-400)" /> {post.read_time_min ?? 1} min de leitura
+              </span>
+            </div>
+          </div>
+        </header>
+
+        {/* Cover image */}
+        {post.cover_image_url && (
+          <div className="blog-post-cover-wrap">
+            <div className="container">
+              <img
+                className="blog-post-cover"
+                src={post.cover_image_url}
+                alt={post.cover_image_alt || post.title}
+                loading="eager"
+              />
+            </div>
+          </div>
+        )}
+
+        {/* Body */}
+        <article className="blog-post-body">
+          <div className="container blog-post-body-inner">
+            <ReactMarkdown
+              remarkPlugins={[remarkGfm]}
+              components={{
+                h2: ({ children }) => <h2 className="t-h2 blog-md-h2">{children}</h2>,
+                h3: ({ children }) => <h3 className="t-h3 blog-md-h3">{children}</h3>,
+                h4: ({ children }) => <h4 className="t-h4 blog-md-h4">{children}</h4>,
+                p:  ({ children }) => <p className="t-body blog-md-p">{children}</p>,
+                a:  ({ href, children }) => <a href={href} className="blog-md-a" target={href?.startsWith("http") ? "_blank" : undefined} rel={href?.startsWith("http") ? "noopener noreferrer" : undefined}>{children}</a>,
+                ul: ({ children }) => <ul className="blog-md-ul">{children}</ul>,
+                ol: ({ children }) => <ol className="blog-md-ol">{children}</ol>,
+                li: ({ children }) => <li className="blog-md-li">{children}</li>,
+                blockquote: ({ children }) => <blockquote className="blog-md-blockquote">{children}</blockquote>,
+                code: ({ inline, children }) => inline
+                  ? <code className="blog-md-code-inline">{children}</code>
+                  : <pre className="blog-md-pre"><code>{children}</code></pre>,
+                img: ({ src, alt }) => <img src={src} alt={alt} className="blog-md-img" loading="lazy" />,
+                hr: () => <hr className="blog-md-hr" />,
+                table: ({ children }) => <div className="blog-md-table-wrap"><table className="blog-md-table">{children}</table></div>,
+              }}
+            >
+              {post.body}
+            </ReactMarkdown>
+
+            {/* Tags */}
+            {post.tags?.length > 0 && (
+              <div className="blog-tags">
+                {post.tags.map((t) => <span key={t} className="blog-tag">{t}</span>)}
+              </div>
+            )}
+
+            {/* Share */}
+            <ShareBar url={postUrl} title={post.title} />
+          </div>
+        </article>
+
+        {/* Related */}
+        {related.length > 0 && (
+          <section className="blog-related-section on-navy">
+            <div className="container">
+              <h2 className="t-h3 blog-related-heading">Artigos relacionados</h2>
+              <div className="blog-related-grid">
+                {related.map((r) => <RelatedCard key={r.id} post={r} />)}
+              </div>
+            </div>
+          </section>
+        )}
+
+        {/* CTA */}
+        <section className="blog-cta-band on-navy">
+          <div className="container blog-cta-inner">
+            <div>
+              <h2 className="t-h3" style={{ color: "var(--cream-500)", margin: 0 }}>Guarde sua mala com a gente.</h2>
+              <p className="t-body" style={{ color: "var(--navy-300)", marginTop: 6 }}>Locker monitorado 24h, a partir de R$ 50/dia. Reserva em segundos.</p>
+            </div>
+            <a className="btn btn-primary btn-cta" href="/">Reservar locker</a>
+          </div>
+        </section>
+      </main>
+
+      <footer className="blog-footer on-navy">
+        <div className="container blog-footer-inner">
+          <MalexLogo height={20} />
+          <span className="t-body-sm" style={{ color: "var(--navy-300)" }}>© {new Date().getFullYear()} Malex.</span>
+          <div className="blog-footer-links">
+            <Link to="/">Site</Link>
+            <Link to="/blog">Blog</Link>
+            <a href={MALEX_CONTACT.whatsapp} target="_blank" rel="noopener noreferrer">WhatsApp</a>
+          </div>
+        </div>
+      </footer>
+    </>
+  );
+}
