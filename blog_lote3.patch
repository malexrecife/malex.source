+    const { data } = await adminListPosts();
+    setPosts(data);
+    setLoading(false);
+  }, []);
+
+  useEffect(() => { load(); }, [load]);
+
+  if (creating || editId !== null) {
+    return (
+      <PostEditor
+        postId={editId}
+        showToast={showToast}
+        onBack={() => { setCreating(false); setEditId(null); load(); }}
+      />
