+/* ============================ BLOG CMS ============================ */
+
+/* Markdown toolbar helper — wraps/inserts syntax at cursor */
+function insertMd(ta, pre, suf = "", placeholder = "texto") {
+  const s = ta.selectionStart, e = ta.selectionEnd;
+  const sel = ta.value.substring(s, e) || placeholder;
+  const newVal = ta.value.substring(0, s) + pre + sel + suf + ta.value.substring(e);
+  const newCursor = s + pre.length + sel.length + suf.length;
+  return { newVal, newCursor };
+}
+
+function linePrefix(ta, prefix) {
+  const s = ta.selectionStart;
+  const lineStart = ta.value.lastIndexOf("\n", s - 1) + 1;
+  const before = ta.value.substring(0, lineStart);
+  const after = ta.value.substring(lineStart);
+  const newVal = before + prefix + after;
+  const newCursor = s + prefix.length;
+  return { newVal, newCursor };
+}
+
+function MdToolbar({ taRef, onChange }) {
+  const apply = (fn) => {
+    const ta = taRef.current;
+    if (!ta) return;
+    const { newVal, newCursor } = fn(ta);
+    onChange(newVal);
+    requestAnimationFrame(() => {
+      ta.focus();
+      ta.setSelectionRange(newCursor, newCursor);
+    });
+  };
+
+  const btn = (label, fn, title) => (
+    <button type="button" className="blog-md-toolbar-btn" title={title || label} onClick={() => apply(fn)}>{label}</button>
+  );
+
+  return (
+    <div className="blog-md-toolbar">
+      {btn("B", (ta) => insertMd(ta, "**", "**", "negrito"), "Negrito")}
+      {btn("I", (ta) => insertMd(ta, "*", "*", "itálico"), "Itálico")}
+      <div className="blog-md-toolbar-sep" />
+      {btn("H2", (ta) => linePrefix(ta, "## "), "Título H2")}
+      {btn("H3", (ta) => linePrefix(ta, "### "), "Título H3")}
+      {btn("H4", (ta) => linePrefix(ta, "#### "), "Título H4")}
+      <div className="blog-md-toolbar-sep" />
+      {btn("— link", (ta) => insertMd(ta, "[", "](https://)", "texto do link"), "Link")}
+      {btn("— img", (ta) => insertMd(ta, "![", "](https://url-da-imagem.jpg)", "alt da imagem"), "Imagem")}
+      <div className="blog-md-toolbar-sep" />
+      {btn("• lista", (ta) => linePrefix(ta, "- "), "Lista com marcadores")}
+      {btn("1. lista", (ta) => linePrefix(ta, "1. "), "Lista numerada")}
+      {btn('" cit.', (ta) => linePrefix(ta, "> "), "Citação / blockquote")}
+      <div className="blog-md-toolbar-sep" />
+      {btn("`code`", (ta) => insertMd(ta, "`", "`", "código"), "Código inline")}
+      {btn("---", (ta) => {
+        const ta2 = taRef.current;
+        const s = ta2.selectionStart;
+        const newVal = ta2.value.substring(0, s) + "\n---\n" + ta2.value.substring(s);
+        return { newVal, newCursor: s + 5 };
+      }, "Linha horizontal")}
+    </div>
+  );
+}
