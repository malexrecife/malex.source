+        </div>
+      ) : (
+        <>
+          <table className="blog-cms-table">
+            <thead>
+              <tr>
+                <th>Título</th>
+                <th>Categoria</th>
+                <th>Status</th>
+                <th>Publicado em</th>
+                <th>Leitura</th>
+                <th></th>
+              </tr>
+            </thead>
+            <tbody>
+              {slice.map((p) => (
+                <tr key={p.id}>
+                  <td style={{ maxWidth: 280 }}>
+                    <span style={{ display: "block", overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>{p.title}</span>
+                    <span className="t-body-sm" style={{ color: "var(--navy-400)" }}>/blog/{p.slug}</span>
+                  </td>
+                  <td><span style={{ color: "var(--navy-300)", fontSize: 13 }}>{p.category}</span></td>
+                  <td>
+                    <span className={`blog-status-pill blog-status-${p.status}`}>
+                      {p.status === "published" ? "Publicado" : "Rascunho"}
+                    </span>
+                  </td>
+                  <td style={{ color: "var(--navy-300)", fontSize: 13 }}>{p.published_at ? fmtDateTime(p.published_at) : "—"}</td>
+                  <td style={{ color: "var(--navy-300)", fontSize: 13 }}>{p.read_time_min ?? "—"} min</td>
+                  <td>
+                    <div style={{ display: "flex", gap: 6 }}>
+                      <button className="adm-link" onClick={() => setEditId(p.id)}>
+                        <Icon name="key" size={14} /> Editar
+                      </button>
+                      {p.status === "published" && (
+                        <a className="adm-link" href={`/blog/${p.slug}`} target="_blank" rel="noopener noreferrer">
+                          <Icon name="arrow-right" size={14} /> Ver
+                        </a>
+                      )}
+                      <button className="adm-link" style={{ color: "var(--error)" }} onClick={async () => {
+                        const ok = await confirm(`Excluir "${p.title}"?`, "Excluir post");
+                        if (!ok) return;
+                        await adminDeletePost(p.id);
+                        showToast("Post excluído.", "info");
+                        load();
+                      }}>
+                        <Icon name="close" size={14} /> Excluir
+                      </button>
+                    </div>
+                  </td>
+                </tr>
+              ))}
+            </tbody>
+          </table>
+          <Paginator page={page} total={total} setPage={setPage} count={count} perPage={20} />
+        </>
+      )}
+    </div>
+  );
+}
