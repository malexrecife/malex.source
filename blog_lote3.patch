+    </div>
+  );
+}
+
+/* ---- Post list ---- */
+function BlogCmsView({ showToast, confirm }) {
+  const [posts, setPosts] = useState([]);
+  const [loading, setLoading] = useState(true);
+  const [editId, setEditId] = useState(null);
+  const [creating, setCreating] = useState(false);
