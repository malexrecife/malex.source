# Supabase — copie este arquivo para `.env` e preencha com os valores do seu projeto.
# Em: Supabase Dashboard → Project Settings → Data API / API Keys.
# Sem estas variáveis, o wizard roda em modo demo (não grava nada).
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SEU_ANON_KEY_PUBLICO
